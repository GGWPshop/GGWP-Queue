# Connection
REDIS_URL=redis://ggwp-redis:6379/0
PORT=8050

# Scraper service
SCRAPER_SERVICE_URL=http://ggwp-scraper-fragment:8020

# Fragment scheduler
FRAGMENT_SCHEDULER_ENABLED=true
FRAGMENT_DISCOVER_CRON=0 0 * * *
FRAGMENT_PRICE_SYNC_CRON=0 * * * *
FRAGMENT_TIMEZONE=Europe/Moscow

# Currency service (required for currency refresh jobs)
CURRENCY_API_URL=http://ggwp-currency-api:9000
CURRENCY_ADMIN_KEY=your-currency-admin-api-key

# Worker settings
WORKER_CONCURRENCY=2
QUEUE_WORKER_ENABLED=true
